{
	"mcpServers": {
		"context7": {
			"type": "streamable-http",
			"url": "https://mcp.context7.com/mcp",
			"alwaysAllow": [
				"resolve-library-id"
			]
		},
		"exa": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-remote",
				"https://mcp.exa.ai/mcp"
			],
			"alwaysAllow": [
				"web_search_exa",
				"crawling_exa",
				"get_code_context_exa"
			]
		}
	}
}