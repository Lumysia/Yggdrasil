APPDATA_PATH=/data/appdata
DB_PATH=/data/db
LOGS_PATH=/data/logs

MYSQL_DATABASE=one-api
MYSQL_USER=oneapi
MYSQL_PASSWORD=oneapipassword
MYSQL_ROOT_PASSWORD=oneapipassword

SQL_DSN=${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(mysql:3306)/${MYSQL_DATABASE}
REDIS_CONN_STRING=redis://redis:6379

# Optional for multi-node deployments.
# NODE_TYPE=slave
# SYNC_FREQUENCY=60
# FRONTEND_BASE_URL=https://oneapi.${COMMON_DOMAIN_A}
