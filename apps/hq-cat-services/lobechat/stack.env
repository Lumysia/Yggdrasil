APPDATA_PATH=/data/appdata
DB_PATH=/data/db
APP_URL=https://lobe.${COMMON_DOMAIN_A}

# Postgres
POSTGRES_PASSWORD=postgres

# Searxng
SEARXNG_SETTINGS_FILE=/etc/searxng/settings.yml

# LobeHub
S3_ENABLE_PATH_STYLE="0"
LLM_VISION_IMAGE_USE_BASE64="1"
SEARXNG_URL=http://searxng:8080
REDIS_URL=redis://redis:6379
REDIS_PREFIX=lobechat
REDIS_TLS="0"
S3_BUCKET=lobechat
S3_PUBLIC_DOMAIN=https://lobe-s3.${COMMON_DOMAIN_A}

AUTH_SSO_PROVIDERS=generic-oidc
AUTH_GENERIC_OIDC_ID=9fcaf2a8-3c57-43b1-a789-f9a95a03d341
AUTH_GENERIC_OIDC_ISSUER=https://id.${COMMON_DOMAIN_A}
AUTH_DISABLE_EMAIL_PASSWORD=1

DEFAULT_FILES_CONFIG=embedding_model=cohere/embed-v4.0
