APPDATA_PATH=/data/appdata
DB_PATH=/data/db
LOGS_PATH=/data/logs

SESSION_SECRET=${HQCAT_SERVICES_NEWAPI_SESSIONSEC}\
CRYPTO_SECRET=${HQCAT_SERVICES_NEWAPI_CRYPTOSEC}

POSTGRES_USER=${POSTGRES_USER:-newapi}
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-newapi_password}
POSTGRES_DB=${POSTGRES_DB:-newapi}

SQL_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgresql:5432/${POSTGRES_DB}
REDIS_CONN_STRING=redis://redis:6379

ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Optional: increase if streaming responses time out.
# STREAMING_TIMEOUT=300
