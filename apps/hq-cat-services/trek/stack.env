APPDATA_PATH=/data/appdata
TIME_ZONE=${TIME_ZONE:-Etc/UTC}

NODE_ENV=production
PORT=3000
TZ=${TIME_ZONE}
LOG_LEVEL=info

APP_URL=https://trek.${COMMON_DOMAIN_A}
ALLOWED_ORIGINS=https://trek.${COMMON_DOMAIN_A}
FORCE_HTTPS=true
TRUST_PROXY=1

