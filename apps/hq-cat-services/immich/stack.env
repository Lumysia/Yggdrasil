APPDATA_PATH=/data/appdata
MEDIA_PATH=/data/media
AIMODELS_PATH=/data/aimodels
DB_PATH=/data/db

# Immich server
DB_PASSWORD=${DB_PASSWORD}
DB_USERNAME=${DB_USERNAME}
