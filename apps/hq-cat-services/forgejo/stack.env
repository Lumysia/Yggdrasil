BLOBSTORE_PATH=/data/blobstore

# Forgejo
USER_UID=1000
USER_GID=1000
FORGEJO__SERVER__DISABLE_SSH=false
FORGEJO__ACTIONS__DEFAULT_ACTIONS_URL=https://github.com
FORGEJO__FEDERATION__ENABLED=true
# FORGEJO__SERVER__START_SSH_SERVER=true
FORGEJO__SERVICE_0x2E_EXPLORE__DISABLE_CODE_PAGE=false
FORGEJO__SERVICE_0x2E_EXPLORE__DISABLE_USERS_PAGE=true
# FORGEJO__SERVICE_0x2E_EXPLORE__DISABLE_ORGANIZATIONS_PAGE=true
FORGEJO__MAILER__ENABLED=true
FORGEJO__MAILER__PROTOCOL=smtps
FORGEJO__MAILER__SMTP_PORT=465
# OIDC Configuration
FORGEJO__SERVICE__ALLOW_ONLY_EXTERNAL_REGISTRATION=true
FORGEJO__SERVICE__ENABLE_INTERNAL_SIGNIN=false
FORGEJO__OAUTH2_CLIENT__ENABLE_AUTO_REGISTRATION=true
FORGEJO__OAUTH2_CLIENT__UPDATE_AVATAR=true
FORGEJO__OAUTH2_CLIENT__ACCOUNT_LINKING=auto
FORGEJO__OAUTH2_CLIENT__REGISTER_EMAIL_CONFIRM=true
# OpenID Configuration
FORGEJO__OPENID__ENABLE_OPENID_SIGNIN=false
FORGEJO__OPENID__ENABLE_OPENID_SIGNUP=false

# Renovate
RENOVATE_PLATFORM=forgejo
RENOVATE_AUTODISCOVER=true
# RENOVATE_AUTODISCOVER_FILTER=my-org,my-user
RENOVATE_REQUIRE_CONFIG=required
LOG_LEVEL=info
